# ===========================================================
#  Hardware AI Compare — variáveis de ambiente
# ===========================================================
# Copie este arquivo para ".env.local" e preencha a chave.
# Sem a chave, o app funciona em MODO DEMONSTRAÇÃO (dados simulados).

# Chave da API da Anthropic (Claude). Crie em: https://console.anthropic.com
# Comece com "sk-ant-..."
ANTHROPIC_API_KEY=

# Modelo do Claude usado para as comparações.
# Padrão: claude-opus-4-8 (mais inteligente). Para reduzir custo: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-opus-4-8

# ===========================================================
#  Supabase (login + banco de dados + histórico) — OPCIONAL
# ===========================================================
# Sem estas variáveis, o app funciona sem login e o histórico fica
# salvo apenas no navegador. Crie um projeto em https://supabase.com
# e pegue os valores em: Project Settings → API.

# URL do projeto, ex: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" (pode ficar no frontend; é protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Endereço do seu site (para o link mágico de login voltar ao lugar certo).
# Local: http://localhost:3000 — Produção: https://seudominio.com.br
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Chave de SERVIÇO do Supabase (Project Settings → API → service_role).
# Usada só no servidor (webhook de pagamento). NUNCA exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================================
#  Mercado Pago (pagamentos / assinaturas) — OPCIONAL
# ===========================================================
# Sem esta chave, os botões de assinatura avisam que o pagamento não está
# configurado. Crie credenciais em: https://www.mercadopago.com.br/developers
# Use o Access Token (começa com APP_USR-...).
MP_ACCESS_TOKEN=

# Limite de comparações por dia no plano grátis (padrão: 3).
# Aumente durante os testes se quiser, ex: 999.
FREE_DAILY_LIMIT=3

# ===========================================================
#  Painel administrativo (/admin) — OPCIONAL
# ===========================================================
# E-mails que podem acessar o painel admin (separados por vírgula).
# Use o MESMO e-mail com que você faz login. Precisa também da
# SUPABASE_SERVICE_ROLE_KEY (acima) para ler as estatísticas.
ADMIN_EMAILS=

# ===========================================================
#  Afiliados (monetização dos links das lojas) — OPCIONAL
# ===========================================================
# Sem preencher, os links das lojas funcionam normal, só não geram comissão.
# Estas são PÚBLICAS (aparecem nos links), por isso usam NEXT_PUBLIC_.

# Amazon Associados — sua tag (ex: besthard-20). Crie em associados.amazon.com.br
NEXT_PUBLIC_AMAZON_TAG=

# Awin (programas da KaBuM, Pichau, Terabyte, Mercado Livre) — opcional.
# Crie conta em awin.com, pegue seu ID de publisher e o merchant ID (MID) de cada loja.
NEXT_PUBLIC_AWIN_AFFID=
NEXT_PUBLIC_AWIN_MID_KABUM=
NEXT_PUBLIC_AWIN_MID_PICHAU=
NEXT_PUBLIC_AWIN_MID_TERABYTE=
NEXT_PUBLIC_AWIN_MID_MERCADOLIVRE=
